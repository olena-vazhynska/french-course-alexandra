          }
        },
        {
          id: "1-1", type: "writing", title: "Expression écrite — Un email professionnel", xp: 70,
          hint_ru: "Написание профессионального письма на французском — обращай внимание на формулы приветствия и прощания.",
          content: {
            prompt: "Rédige un email à ton médecin genevois pour prendre rendez-vous. Inclus : ton nom, le motif de la consultation, tes disponibilités (2 options), et une formule de politesse.",
            starter: "Madame, Monsieur,\n\nJe me permets de vous contacter afin de...",
            tips: ["Utilise 'Je me permets de...' pour commencer poliment", "Propose deux créneaux : 'Le mardi 10 juin ou le jeudi 12 juin me conviendraient.'", "Termine par : 'Veuillez agréer, Madame/Monsieur, mes salutations distinguées.'"],
            hint_ru_detail: "Формулы: 'Je me permets de vous contacter' = Позвольте обратиться к вам. 'Veuillez agréer mes salutations distinguées' = С уважением (официально)."
          }
        },
        {
          id: "1-2", type: "quiz", title: "Quiz — Vocabulaire médical", xp: 40,
          hint_ru: "Медицинская лексика — пригодится в любой франкоязычной стране!",
          content: {
            questions: [
              { q: "Comment dit-on 'ordonnance' en français ?", options: ["ordination", "prescription", "ordonnance", "réservation"], answer: 2 },
              { q: "Que veut dire 'avoir de la fièvre' ?", options: ["avoir faim", "avoir chaud", "avoir de la température élevée", "avoir mal au dos"], answer: 2 },
              { q: "Quel est le synonyme de 'médecin' ?", options: ["infirmier", "docteur", "pharmacien", "dentiste"], answer: 1 },
              { q: "Qu'est-ce qu'une 'franchise' dans le contexte médical ?", options: ["Une clinique gratuite", "Le montant à payer soi-même avant remboursement", "Un type de médicament", "Un remboursement immédiat"], answer: 1 },
            ]
          }
        },
      ]
    },
    {
      id: 2, icon: "🍫", city: "Bruxelles, Belgique", title: "À Bruxelles",
      color: "#d97706", bg: "#fffbeb",
      lessons: [
        {
          id: "2-0", type: "dialogue", title: "Au marché", xp: 30,
          hint_ru: "Разговор на рынке — практикуй числа, количества и торг!",
          content: {
            lines: [
              { speaker: "Vendeur", text: "Bonjour ! Qu'est-ce qu'il vous faut aujourd'hui ?" },
              { speaker: "Alexandra", text: "Bonjour ! Je voudrais un kilo de tomates et une botte de persil, s'il vous plaît." },
              { speaker: "Vendeur", text: "Voilà ! Et avec ça ?" },
              { speaker: "Alexandra", text: "C'est combien pour les fraises ? Elles ont l'air délicieuses !" },
              { speaker: "Vendeur", text: "Trois euros la barquette. Si vous en prenez deux, je vous fais un prix !" },
              { speaker: "Alexandra", text: "D'accord, je prends deux barquettes alors. Merci !" },
            ],
            vocab: [
              { fr: "une botte de persil", ru: "пучок петрушки" },
              { fr: "une barquette", ru: "лоток/упаковка" },
              { fr: "Ils ont l'air...", ru: "Они выглядят..." },
              { fr: "je vous fais un prix", ru: "сделаю вам скидку" },
              { fr: "Et avec ça ?", ru: "Что-нибудь ещё?" },
            ]
          }
        },
        {
          id: "2-1", type: "fillin", title: "Grammaire — Le conditionnel", xp: 50,
          hint_ru: "Кондиционал (conditionnel présent) — вежливые просьбы и гипотетические ситуации. Образуется: инфинитив + окончания -ais, -ais, -ait, -ions, -iez, -aient.",
          content: {
            explanation: "Le conditionnel présent exprime la politesse, le souhait ou une hypothèse. Exemple : 'Je voudrais un café' est plus poli que 'Je veux un café'.",
            sentences: [
              { before: "Est-ce que vous ", blank: "pourriez", after: " m'indiquer la rue du Marché ?", options: ["pouvez", "pourriez", "pouviez", "puissiez"] },
              { before: "J'", blank: "aimerais", after: " goûter les gaufres belges.", options: ["aime", "aimais", "aimerais", "aimerai"] },
              { before: "Si j'avais le temps, je ", blank: "visiterais", after: " le Manneken Pis.", options: ["visite", "visitais", "visiterai", "visiterais"] },
            ]
          }
        },
        {
          id: "2-2", type: "scenario", title: "Scénario — Au restaurant belge", xp: 60,
          hint_ru: "Заказ в ресторане — используй кондиционал для вежливости!",
          content: {
            setup: "Tu es dans une brasserie bruxelloise. Le serveur s'approche.",
            exchanges: [
              { speaker: "Serveur", text: "Bonsoir ! Vous avez choisi ?", options: ["Oui, donnez-moi des moules.", "Je voudrais les moules-frites, s'il vous plaît.", "Je veux manger maintenant."], correct: 1, feedback: ["Trop direct — le conditionnel serait plus poli!", "Parfait ! Poli et naturel 🍟🦪", "Trop brusque — essaie avec 'je voudrais'!"] },
              { speaker: "Serveur", text: "Et comme boisson ?", options: ["De l'eau gazeuse, s'il vous plaît.", "De l'eau.", "Rien."], correct: 0, feedback: ["Excellent ! Complet et poli 👏", "Correct mais incomplet — ajoute 's'il vous plaît' !", "C'est un peu sec..."] },
            ]
          }
        },
      ]
    },
    {
      id: 3, icon: "🌴", city: "Martinique", title: "En Martinique",
      color: "#16a34a", bg: "#f0fdf4",
      lessons: [
        {
          id: "3-0", type: "reading", title: "Lecture — La culture créole", xp: 40,
          hint_ru: "Чтение о культуре Мартиники — обращай внимание на незнакомые слова и угадывай их из контекста!",
          content: {
            text: `La Martinique est un département français d'outre-mer situé dans les Caraïbes. On y parle français, mais aussi le créole martiniquais, une langue mêlant le français, l'africain et des influences amérindiennes.\n\nLa culture martiniquaise est riche et colorée. Le zouk, né aux Antilles, est un genre musical incontournable. La cuisine locale mélange épices, poissons frais et légumes tropicaux. Le plat traditionnel est le « colombo », un curry antillais parfumé.\n\nLes Martiniquais sont réputés pour leur chaleur humaine et leur joie de vivre. Si tu visites l'île, n'oublie pas de goûter les accras de morue — de délicieux beignets de poisson !`,
            questions: [
              { q: "Quelles langues parle-t-on en Martinique ?", options: ["Français seulement", "Créole seulement", "Français et créole", "Espagnol et français"], answer: 2 },
              { q: "Qu'est-ce que le 'colombo' ?", options: ["Une danse antillaise", "Un curry antillais", "Un fruit tropical", "Un instrument de musique"], answer: 1 },
            ]
          }
        },
        {
          id: "3-1", type: "quiz", title: "Quiz final — Tour du monde francophone", xp: 80,
          hint_ru: "Финальный тест по всему курсу! Ты молодец — почти у цели 🎉",
          content: {
            questions: [
              { q: "Quel est le subjonctif du verbe 'être' à la 2e personne du singulier ?", options: ["es", "seras", "sois", "étais"], answer: 2 },
              { q: "Comment dit-on 'Je voudrais réserver une table' poliment ?", options: ["Je veux une table", "Donnez-moi une table", "Je voudrais réserver une table, s'il vous plaît", "Une table maintenant"], answer: 2 },
              { q: "Que signifie 'la LAMal' en Suisse ?", options: ["Un train suisse", "L'assurance maladie obligatoire", "Un musée genevois", "Un parti politique"], answer: 1 },
              { q: "Quel est l'équivalent de 'Et avec ça ?' en français courant ?", options: ["C'est tout ?", "Vous voulez autre chose ?", "Quoi d'autre ?", "Toutes ces réponses"], answer: 3 },
              { q: "Quel genre musical est né aux Antilles ?", options: ["Reggae", "Salsa", "Zouk", "Bossa nova"], answer: 2 },
            ]
          }
        },
        {
          id: "3-2", type: "writing", title: "Défi final — Carte postale de Martinique", xp: 80,
          hint_ru: "Финальное творческое задание! Напиши открытку другу из Мартиники — используй прошедшее время (passé composé) и описания.",
          content: {
            prompt: "Écris une carte postale à ton ami(e) depuis la Martinique (80-100 mots). Décris : le temps qu'il fait, ce que tu as vu, ce que tu as mangé, et ce que tu vas faire demain.",
            starter: "Chère/Cher ...,\n\nMe voilà en Martinique ! Le soleil...",
            tips: ["Utilise le passé composé : 'J'ai visité...', 'Nous avons mangé...'", "Décris avec des adjectifs : magnifique, coloré, épicé, chaleureux", "Pour demain : 'Je vais aller à la plage / goûter les accras'"],
            hint_ru_detail: "Passé composé напоминалка: avoir/être + причастие. 'J'ai mangé' (я съела), 'Je suis allée' (я пошла — глаголы движения с être!)."
          }
        },
      ]
    }
  ]
};

const BADGES = [
  { id: "first_step", icon: "👣", label: "Premier Pas", condition: xp => xp >= 30 },
  { id: "halfway", icon: "⭐", label: "Mi-Parcours", condition: xp => xp >= 200 },
  { id: "grammar_pro", icon: "📚", label: "Grammairienne", condition: (xp, done) => done.some(id => id.includes("fillin")) },
  { id: "storyteller", icon: "✍️", label: "Plume d'or", condition: (xp, done) => done.some(id => id.includes("writing")) },
  { id: "champion", icon: "🏆", label: "Championne B1", condition: xp => xp >= 600 },
];

const MAX_XP = COURSE.modules.reduce((s, m) => s + m.lessons.reduce((ss, l) => ss + l.xp, 0), 0);

function App() {
  const [screen, setScreen] = useState("home");
  const [activeModule, setActiveModule] = useState(null);
  const [activeLesson, setActiveLesson] = useState(null);
  const [completedLessons, setCompletedLessons] = useState([]);
  const [xp, setXp] = useState(0);
  const [showHint, setShowHint] = useState(false);
  const [lessonState, setLessonState] = useState({});

  const totalLessons = COURSE.modules.reduce((s, m) => s + m.lessons.length, 0);
  const progress = Math.round((completedLessons.length / totalLessons) * 100);
  const earnedBadges = BADGES.filter(b => b.condition(xp, completedLessons));

  const completeLesson = useCallback((lessonId, earnedXp) => {
    if (!completedLessons.includes(lessonId)) {
      setCompletedLessons(p => [...p, lessonId]);
      setXp(p => p + earnedXp);
    }
    const mod = COURSE.modules[activeModule];
    const lessonIdx = mod.lessons.findIndex(l => l.id === lessonId);
    if (lessonIdx < mod.lessons.length - 1) {
      setActiveLesson(lessonIdx + 1);
      setShowHint(false);
      setLessonState({});
    } else {
      setScreen("module_complete");
    }
  }, [completedLessons, activeModule]);

  return (
    <div style={{ minHeight: "100vh", background: "#f8fafc", fontFamily: "'Segoe UI', sans-serif" }}>
      {screen === "home" && <HomeScreen setScreen={setScreen} setActiveModule={setActiveModule} setActiveLesson={setActiveLesson} setShowHint={setShowHint} setLessonState={setLessonState} completedLessons={completedLessons} xp={xp} progress={progress} earnedBadges={earnedBadges} />}
      {screen === "module" && <ModuleScreen mod={COURSE.modules[activeModule]} completedLessons={completedLessons} setScreen={setScreen} setActiveLesson={setActiveLesson} setShowHint={setShowHint} setLessonState={setLessonState} />}
      {screen === "lesson" && <LessonScreen lesson={COURSE.modules[activeModule].lessons[activeLesson]} mod={COURSE.modules[activeModule]} showHint={showHint} setShowHint={setShowHint} lessonState={lessonState} setLessonState={setLessonState} completeLesson={completeLesson} completedLessons={completedLessons} setScreen={setScreen} />}
      {screen === "module_complete" && <ModuleCompleteScreen mod={COURSE.modules[activeModule]} setScreen={setScreen} xp={xp} maxXp={MAX_XP} earnedBadges={earnedBadges} />}
    </div>
  );
}

function HomeScreen({ setScreen, setActiveModule, setActiveLesson, setShowHint, setLessonState, completedLessons, xp, progress, earnedBadges }) {
  return (
    <div style={{ maxWidth: 700, margin: "0 auto", padding: "24px 16px" }}>
      <div style={{ textAlign: "center", marginBottom: 28 }}>
        <div style={{ fontSize: 48 }}>🇫🇷</div>
        <h1 style={{ fontSize: 26, fontWeight: 800, color: "#1e293b", margin: "8px 0 4px" }}>{COURSE.title}</h1>
        <p style={{ color: "#64748b", fontSize: 15 }}>{COURSE.subtitle}</p>
      </div>
      <div style={{ background: "#fff", borderRadius: 16, padding: 20, marginBottom: 20, boxShadow: "0 2px 8px #0001" }}>
        <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 8 }}>
          <span style={{ fontWeight: 700, color: "#1e293b" }}>Progression</span>
          <span style={{ color: "#6366f1", fontWeight: 700 }}>{xp} XP</span>
        </div>
        <div style={{ background: "#e2e8f0", borderRadius: 99, height: 12, overflow: "hidden" }}>
          <div style={{ width: `${progress}%`, background: "linear-gradient(90deg,#6366f1,#a855f7)", height: "100%", borderRadius: 99, transition: "width .5s" }} />
        </div>
        <div style={{ display: "flex", justifyContent: "space-between", marginTop: 6, fontSize: 13, color: "#94a3b8" }}>
          <span>{completedLessons.length}/{COURSE.modules.reduce((s, m) => s + m.lessons.length, 0)} leçons</span>
          <span>{progress}%</span>
        </div>
      </div>
      {earnedBadges.length > 0 && (
        <div style={{ background: "#fff", borderRadius: 16, padding: 16, marginBottom: 20, boxShadow: "0 2px 8px #0001" }}>
          <div style={{ fontWeight: 700, color: "#1e293b", marginBottom: 10 }}>🏅 Badges obtenus</div>
          <div style={{ display: "flex", gap: 12, flexWrap: "wrap" }}>
            {earnedBadges.map(b => (
              <div key={b.id} style={{ textAlign: "center", background: "#faf5ff", border: "2px solid #a855f7", borderRadius: 12, padding: "8px 14px" }}>
                <div style={{ fontSize: 22 }}>{b.icon}</div>
                <div style={{ fontSize: 11, fontWeight: 600, color: "#7c3aed" }}>{b.label}</div>
              </div>
            ))}
          </div>
        </div>
      )}
      <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
        {COURSE.modules.map((mod, idx) => {
          const done = mod.lessons.filter(l => completedLessons.includes(l.id)).length;
          const total = mod.lessons.length;
          const pct = Math.round((done / total) * 100);
          return (
            <div key={mod.id} onClick={() => { setActiveModule(idx); setActiveLesson(0); setShowHint(false); setLessonState({}); setScreen("module"); }}
              style={{ background: mod.bg, border: `2px solid ${mod.color}30`, borderRadius: 16, padding: "18px 20px", cursor: "pointer", display: "flex", alignItems: "center", gap: 16, boxShadow: "0 2px 8px #0001" }}>
              <div style={{ fontSize: 36 }}>{mod.icon}</div>
              <div style={{ flex: 1 }}>
                <div style={{ fontWeight: 700, color: "#1e293b", fontSize: 16 }}>{mod.title}</div>
                <div style={{ color: "#64748b", fontSize: 13 }}>{mod.city} · {total} leçons</div>
                <div style={{ background: "#e2e8f0", borderRadius: 99, height: 6, marginTop: 8, overflow: "hidden" }}>
                  <div style={{ width: `${pct}%`, background: mod.color, height: "100%", borderRadius: 99 }} />
                </div>
              </div>
              <div style={{ color: mod.color, fontWeight: 800, fontSize: 18 }}>{done}/{total}</div>
            </div>
          );
        })}
      </div>
      <div style={{ textAlign: "center", color: "#94a3b8", fontSize: 13, marginTop: 24 }}>
        ⏱ Durée estimée : 4 heures · Niveau B1 · Russe disponible 🇷🇺
      </div>
    </div>
  );
}

function ModuleScreen({ mod, completedLessons, setScreen, setActiveLesson, setShowHint, setLessonState }) {
  return (
    <div style={{ maxWidth: 700, margin: "0 auto", padding: "24px 16px" }}>
      <button onClick={() => setScreen("home")} style={{ background: "none", border: "none", color: mod.color, fontWeight: 700, cursor: "pointer", fontSize: 15, marginBottom: 16 }}>← Retour</button>
      <div style={{ background: mod.bg, borderRadius: 20, padding: "24px 20px", marginBottom: 20, border: `2px solid ${mod.color}30` }}>
        <div style={{ fontSize: 40, marginBottom: 8 }}>{mod.icon}</div>
        <h2 style={{ fontSize: 22, fontWeight: 800, color: "#1e293b", margin: "0 0 4px" }}>{mod.title}</h2>
        <div style={{ color: "#64748b", fontSize: 14 }}>{mod.city}</div>
      </div>
      <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
        {mod.lessons.map((lesson, idx) => {
          const done = completedLessons.includes(lesson.id);
          return (
            <div key={lesson.id} onClick={() => { setActiveLesson(idx); setShowHint(false); setLessonState({}); setScreen("lesson"); }}
              style={{ background: "#fff", borderRadius: 14, padding: "16px 18px", cursor: "pointer", display: "flex", alignItems: "center", gap: 14, border: `2px solid ${done ? mod.color : "#e2e8f0"}`, boxShadow: "0 1px 4px #0001" }}>
              <div style={{ fontSize: 24 }}>{done ? "✅" : typeIcon(lesson.type)}</div>
              <div style={{ flex: 1 }}>
                <div style={{ fontWeight: 700, color: "#1e293b" }}>{lesson.title}</div>
                <div style={{ color: "#94a3b8", fontSize: 13, textTransform: "capitalize" }}>{lesson.type} · {lesson.xp} XP</div>
              </div>
              {done && <span style={{ color: mod.color, fontWeight: 800 }}>✓</span>}
            </div>
          );
        })}
      </div>
    </div>
  );
}

function typeIcon(type) {
  return { dialogue: "💬", quiz: "❓", fillin: "📝", scenario: "🎭", reading: "📖", writing: "✍️" }[type] || "📋";
}

function LessonScreen({ lesson, mod, showHint, setShowHint, lessonState, setLessonState, completeLesson, completedLessons, setScreen }) {
  const alreadyDone = completedLessons.includes(lesson.id);
  return (
    <div style={{ maxWidth: 700, margin: "0 auto", padding: "24px 16px" }}>
      <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 20 }}>
        <button onClick={() => setScreen("module")} style={{ background: "none", border: "none", color: mod.color, fontWeight: 700, cursor: "pointer", fontSize: 15 }}>← Module</button>
        <div style={{ flex: 1 }} />
        <button onClick={() => setShowHint(!showHint)} style={{ background: showHint ? "#fef3c7" : "#f1f5f9", border: "none", borderRadius: 99, padding: "6px 14px", cursor: "pointer", fontWeight: 600, fontSize: 13, color: "#92400e" }}>
          {showHint ? "🇷🇺 Скрыть" : "🇷🇺 Подсказка"}
        </button>
      </div>
      {showHint && (
        <div style={{ background: "#fef3c7", border: "1.5px solid #fbbf24", borderRadius: 12, padding: "12px 16px", marginBottom: 16, fontSize: 14, color: "#92400e" }}>
          💡 {lesson.hint_ru}
        </div>
      )}
      <div style={{ background: "#fff", borderRadius: 20, padding: "24px 20px", boxShadow: "0 2px 8px #0001" }}>
        <div style={{ display: "flex", gap: 10, alignItems: "center", marginBottom: 18 }}>
          <span style={{ fontSize: 26 }}>{typeIcon(lesson.type)}</span>
          <div>
            <h2 style={{ margin: 0, fontSize: 18, fontWeight: 800, color: "#1e293b" }}>{lesson.title}</h2>
            <span style={{ color: mod.color, fontWeight: 700, fontSize: 13 }}>{lesson.xp} XP</span>
          </div>
        </div>
        {lesson.type === "dialogue" && <DialogueLesson lesson={lesson} mod={mod} lessonState={lessonState} setLessonState={setLessonState} completeLesson={completeLesson} alreadyDone={alreadyDone} />}
        {lesson.type === "quiz" && <QuizLesson lesson={lesson} mod={mod} lessonState={lessonState} setLessonState={setLessonState} completeLesson={completeLesson} alreadyDone={alreadyDone} />}
        {lesson.type === "fillin" && <FillinLesson lesson={lesson} mod={mod} showHint={showHint} lessonState={lessonState} setLessonState={setLessonState} completeLesson={completeLesson} alreadyDone={alreadyDone} />}
        {lesson.type === "scenario" && <ScenarioLesson lesson={lesson} mod={mod} lessonState={lessonState} setLessonState={setLessonState} completeLesson={completeLesson} alreadyDone={alreadyDone} />}
        {lesson.type === "reading" && <ReadingLesson lesson={lesson} mod={mod} lessonState={lessonState} setLessonState={setLessonState} completeLesson={completeLesson} alreadyDone={alreadyDone} />}
        {lesson.type === "writing" && <WritingLesson lesson={lesson} mod={mod} showHint={showHint} lessonState={lessonState} setLessonState={setLessonState} completeLesson={completeLesson} alreadyDone={alreadyDone} />}
      </div>
    </div>
  );
}

function Btn({ onClick, children, color, disabled }) {
  return (
    <button onClick={onClick} disabled={disabled}
      style={{ background: disabled ? "#e2e8f0" : color, color: disabled ? "#94a3b8" : "#fff", border: "none", borderRadius: 99, padding: "12px 28px", fontWeight: 700, fontSize: 15, cursor: disabled ? "not-allowed" : "pointer", marginTop: 16 }}>
      {children}
    </button>
  );
}

function DialogueLesson({ lesson, mod, lessonState, setLessonState, completeLesson, alreadyDone }) {
  const [showVocab, setShowVocab] = useState(false);
  return (
    <div>
      <div style={{ display: "flex", flexDirection: "column", gap: 12, marginBottom: 20 }}>
        {lesson.content.lines.map((line, i) => (
          <div key={i} style={{ display: "flex", gap: 10, flexDirection: line.speaker === "Alexandra" ? "row-reverse" : "row" }}>
            <div style={{ fontSize: 20 }}>{line.speaker === "Alexandra" ? "👩" : "🧑‍💼"}</div>
            <div style={{ background: line.speaker === "Alexandra" ? mod.bg : "#f1f5f9", border: `1.5px solid ${line.speaker === "Alexandra" ? mod.color + "40" : "#e2e8f0"}`, borderRadius: 14, padding: "10px 14px", maxWidth: "80%" }}>
              <div style={{ fontSize: 11, fontWeight: 700, color: "#94a3b8", marginBottom: 4 }}>{line.speaker}</div>
              <div style={{ fontSize: 15, color: "#1e293b" }}>{line.text}</div>
            </div>
          </div>
        ))}
      </div>
      <button onClick={() => setShowVocab(!showVocab)} style={{ background: "#f1f5f9", border: "none", borderRadius: 99, padding: "8px 18px", cursor: "pointer", fontWeight: 600, fontSize: 13, color: "#475569" }}>
        {showVocab ? "▲ Masquer le vocabulaire" : "▼ Voir le vocabulaire"}
      </button>
      {showVocab && (
        <div style={{ marginTop: 12, display: "flex", flexDirection: "column", gap: 8 }}>
          {lesson.content.vocab.map((v, i) => (
            <div key={i} style={{ display: "flex", gap: 8, background: "#f8fafc", borderRadius: 8, padding: "8px 12px" }}>
              <span style={{ fontWeight: 700, color: mod.color }}>{v.fr}</span>
              <span style={{ color: "#64748b" }}>—</span>
              <span style={{ color: "#475569" }}>{v.ru}</span>
            </div>
          ))}
        </div>
      )}
      <div style={{ marginTop: 16 }}>
        <Btn onClick={() => completeLesson(lesson.id, lesson.xp)} color={mod.color} disabled={alreadyDone}>
          {alreadyDone ? "✓ Complété" : "Continuer →"}
        </Btn>
      </div>
    </div>
  );
}

function QuizLesson({ lesson, mod, lessonState, setLessonState, completeLesson, alreadyDone }) {
  const { answers = {}, submitted = false } = lessonState;
  const qs = lesson.content.questions;
  const allAnswered = qs.every((_, i) => answers[i] !== undefined);
  const score = qs.filter((q, i) => answers[i] === q.answer).length;
  return (
    <div>
      {qs.map((q, qi) => (
        <div key={qi} style={{ marginBottom: 20 }}>
          <div style={{ fontWeight: 700, color: "#1e293b", marginBottom: 10 }}>{qi + 1}. {q.q}</div>
          <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
            {q.options.map((opt, oi) => {
              let bg = "#f1f5f9", border = "#e2e8f0", color = "#1e293b";
              if (submitted) {
                if (oi === q.answer) { bg = "#dcfce7"; border = "#16a34a"; color = "#166534"; }
                else if (answers[qi] === oi) { bg = "#fee2e2"; border = "#dc2626"; color = "#7f1d1d"; }
              } else if (answers[qi] === oi) { bg = mod.bg; border = mod.color; color = mod.color; }
              return (
                <div key={oi} onClick={() => { if (!submitted) setLessonState(p => ({ ...p, answers: { ...p.answers, [qi]: oi } })); }}
                  style={{ background: bg, border: `2px solid ${border}`, borderRadius: 10, padding: "10px 14px", cursor: submitted ? "default" : "pointer", color, fontWeight: answers[qi] === oi ? 700 : 400 }}>
                  {opt}
                </div>
              );
            })}
          </div>
        </div>
      ))}
      {!submitted ? (
        <Btn onClick={() => setLessonState(p => ({ ...p, submitted: true }))} color={mod.color} disabled={!allAnswered}>Vérifier les réponses</Btn>
      ) : (
        <div>
          <div style={{ background: score === qs.length ? "#dcfce7" : "#fef3c7", borderRadius: 12, padding: "14px 18px", marginTop: 12, fontWeight: 700, color: score === qs.length ? "#166534" : "#92400e" }}>
            {score === qs.length ? "🎉 Parfait ! Toutes les réponses sont correctes !" : `✅ ${score}/${qs.length} — Regarde les réponses correctes en vert.`}
          </div>
          <Btn onClick={() => completeLesson(lesson.id, lesson.xp)} color={mod.color} disabled={alreadyDone}>
            {alreadyDone ? "✓ Complété" : "Continuer →"}
          </Btn>
        </div>
      )}
    </div>
  );
}

function FillinLesson({ lesson, mod, showHint, lessonState, setLessonState, completeLesson, alreadyDone }) {
  const { answers = {}, submitted = false } = lessonState;
  const sents = lesson.content.sentences;
  const allAnswered = sents.every((_, i) => answers[i] !== undefined);
  const score = sents.filter((s, i) => answers[i] === s.blank).length;
  return (
    <div>
      <div style={{ background: "#f0fdf4", border: "1.5px solid #bbf7d0", borderRadius: 12, padding: "12px 16px", marginBottom: 18, fontSize: 14, color: "#166534" }}>
        📖 {lesson.content.explanation}
      </div>
      {showHint && <div style={{ background: "#fef3c7", border: "1.5px solid #fbbf24", borderRadius: 12, padding: "12px 16px", marginBottom: 18, fontSize: 14, color: "#92400e" }}>🇷🇺 {lesson.hint_ru}</div>}
      {sents.map((s, i) => {
        const chosen = answers[i];
        let borderColor = "#e2e8f0";
        if (submitted) borderColor = chosen === s.blank ? "#16a34a" : "#dc2626";
        else if (chosen) borderColor = mod.color;
        return (
          <div key={i} style={{ marginBottom: 18 }}>
            <div style={{ fontSize: 15, color: "#1e293b", marginBottom: 10, lineHeight: 1.6 }}>
              {s.before}<span style={{ background: chosen ? (submitted ? (chosen === s.blank ? "#dcfce7" : "#fee2e2") : mod.bg) : "#f1f5f9", border: `2px solid ${borderColor}`, borderRadius: 8, padding: "2px 10px", fontWeight: 700, color: mod.color }}>{chosen || "___"}</span>{s.after}
            </div>
            {submitted && chosen !== s.blank && <div style={{ fontSize: 13, color: "#16a34a", marginBottom: 6 }}>✓ Réponse correcte : <strong>{s.blank}</strong></div>}
            <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
              {s.options.map((opt, oi) => {
                let bg = "#f1f5f9", border = "#e2e8f0", col = "#475569";
                if (chosen === opt) { bg = mod.bg; border = mod.color; col = mod.color; }
                return <div key={oi} onClick={() => { if (!submitted) setLessonState(p => ({ ...p, answers: { ...p.answers, [i]: opt } })); }} style={{ background: bg, border: `2px solid ${border}`, borderRadius: 99, padding: "6px 16px", cursor: submitted ? "default" : "pointer", color: col, fontWeight: 600, fontSize: 14 }}>{opt}</div>;
              })}
            </div>
          </div>
        );
      })}
      {!submitted ? (
        <Btn onClick={() => setLessonState(p => ({ ...p, submitted: true }))} color={mod.color} disabled={!allAnswered}>Vérifier</Btn>
      ) : (
        <div>
          <div style={{ background: score === sents.length ? "#dcfce7" : "#fef3c7", borderRadius: 12, padding: "12px 16px", fontWeight: 700, color: score === sents.length ? "#166534" : "#92400e", marginTop: 8 }}>
            {score === sents.length ? "🎉 Parfait !" : `${score}/${sents.length} — Regarde les corrections en vert.`}
          </div>
          <Btn onClick={() => completeLesson(lesson.id, lesson.xp)} color={mod.color} disabled={alreadyDone}>{alreadyDone ? "✓ Complété" : "Continuer →"}</Btn>
        </div>
      )}
    </div>
  );
}

function ScenarioLesson({ lesson, mod, lessonState, setLessonState, completeLesson, alreadyDone }) {
  const { step = 0, choices = {}, done = false } = lessonState;
  const exchanges = lesson.content.exchanges;
  const choose = (oi) => {
    const newChoices = { ...choices, [step]: oi };
    const isLast = step === exchanges.length - 1;
    setLessonState({ step: isLast ? step : step + 1, choices: newChoices, done: isLast });
  };
  return (
    <div>
      <div style={{ background: "#f0f9ff", border: "1.5px solid #bae6fd", borderRadius: 12, padding: "12px 16px", marginBottom: 18, fontSize: 14, color: "#0369a1" }}>🎭 {lesson.content.setup}</div>
      {exchanges.map((ex, i) => {
        if (i > step && !done) return null;
        const chosen = choices[i];
        return (
          <div key={i} style={{ marginBottom: 20 }}>
            <div style={{ display: "flex", gap: 10, marginBottom: 10 }}>
              <div style={{ fontSize: 20 }}>👤</div>
              <div style={{ background: "#f1f5f9", borderRadius: 14, padding: "10px 14px" }}>
                <div style={{ fontSize: 11, fontWeight: 700, color: "#94a3b8", marginBottom: 4 }}>{ex.speaker}</div>
                <div style={{ fontSize: 15, color: "#1e293b" }}>{ex.text}</div>
              </div>
            </div>
            {ex.options.map((opt, oi) => {
              const isChosen = chosen === oi;
              const correct = ex.correct === oi;
              let bg = "#f1f5f9", border = "#e2e8f0", col = "#475569";
              if (chosen !== undefined) {
                if (correct) { bg = "#dcfce7"; border = "#16a34a"; col = "#166534"; }
                else if (isChosen) { bg = "#fee2e2"; border = "#dc2626"; col = "#7f1d1d"; }
              }
              return <div key={oi} onClick={() => { if (chosen === undefined && i === step) choose(oi); }} style={{ background: bg, border: `2px solid ${border}`, borderRadius: 12, padding: "10px 14px", cursor: chosen === undefined && i === step ? "pointer" : "default", color: col, fontWeight: isChosen ? 700 : 400, marginBottom: 8, marginLeft: 32, fontSize: 14 }}>👩 {opt}</div>;
            })}
            {chosen !== undefined && <div style={{ marginLeft: 32, background: ex.correct === chosen ? "#dcfce7" : "#fef3c7", border: `1.5px solid ${ex.correct === chosen ? "#16a34a" : "#fbbf24"}`, borderRadius: 10, padding: "8px 14px", fontSize: 13, fontWeight: 600, color: ex.correct === chosen ? "#166534" : "#92400e" }}>{ex.feedback[chosen]}</div>}
          </div>
        );
      })}
      {done && <Btn onClick={() => completeLesson(lesson.id, lesson.xp)} color={mod.color} disabled={alreadyDone}>{alreadyDone ? "✓ Complété" : "Continuer →"}</Btn>}
    </div>
  );
}

function ReadingLesson({ lesson, mod, lessonState, setLessonState, completeLesson, alreadyDone }) {
  const { answers = {}, submitted = false } = lessonState;
  const qs = lesson.content.questions;
  const allAnswered = qs.every((_, i) => answers[i] !== undefined);
  const score = qs.filter((q, i) => answers[i] === q.answer).length;
  return (
    <div>
      <div style={{ background: "#f8fafc", border: "1.5px solid #e2e8f0", borderRadius: 12, padding: "16px 18px", marginBottom: 20, fontSize: 15, lineHeight: 1.8, color: "#1e293b", whiteSpace: "pre-line" }}>{lesson.content.text}</div>
      <div style={{ fontWeight: 700, color: "#1e293b", marginBottom: 14 }}>📋 Questions de compréhension :</div>
      {qs.map((q, qi) => (
        <div key={qi} style={{ marginBottom: 18 }}>
          <div style={{ fontWeight: 600, color: "#1e293b", marginBottom: 8 }}>{qi + 1}. {q.q}</div>
          <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
            {q.options.map((opt, oi) => {
              let bg = "#f1f5f9", border = "#e2e8f0", col = "#1e293b";
              if (submitted) {
                if (oi === q.answer) { bg = "#dcfce7"; border = "#16a34a"; col = "#166534"; }
                else if (answers[qi] === oi) { bg = "#fee2e2"; border = "#dc2626"; col = "#7f1d1d"; }
              } else if (answers[qi] === oi) { bg = mod.bg; border = mod.color; col = mod.color; }
              return <div key={oi} onClick={() => { if (!submitted) setLessonState(p => ({ ...p, answers: { ...p.answers, [qi]: oi } })); }} style={{ background: bg, border: `2px solid ${border}`, borderRadius: 10, padding: "10px 14px", cursor: submitted ? "default" : "pointer", color: col, fontWeight: answers[qi] === oi ? 700 : 400 }}>{opt}</div>;
            })}
          </div>
        </div>
      ))}
      {!submitted ? (
        <Btn onClick={() => setLessonState(p => ({ ...p, submitted: true }))} color={mod.color} disabled={!allAnswered}>Vérifier</Btn>
      ) : (
        <div>
          <div style={{ background: score === qs.length ? "#dcfce7" : "#fef3c7", borderRadius: 12, padding: "12px 16px", fontWeight: 700, color: score === qs.length ? "#166534" : "#92400e", marginTop: 8 }}>
            {score === qs.length ? "🎉 Parfait !" : `${score}/${qs.length} — Relis le texte pour les corrections.`}
          </div>
          <Btn onClick={() => completeLesson(lesson.id, lesson.xp)} color={mod.color} disabled={alreadyDone}>{alreadyDone ? "✓ Complété" : "Continuer →"}</Btn>
        </div>
      )}
    </div>
  );
}

function WritingLesson({ lesson, mod, showHint, lessonState, setLessonState, completeLesson, alreadyDone }) {
  const { text = lesson.content.starter, submitted = false } = lessonState;
  const wordCount = text.trim().split(/\s+/).filter(Boolean).length;
  return (
    <div>
      <div style={{ background: mod.bg, border: `1.5px solid ${mod.color}40`, borderRadius: 12, padding: "12px 16px", marginBottom: 16, fontSize: 14, color: "#1e293b" }}>✍️ <strong>Consigne :</strong> {lesson.content.prompt}</div>
      {showHint && lesson.content.hint_ru_detail && <div style={{ background: "#fef3c7", border: "1.5px solid #fbbf24", borderRadius: 12, padding: "12px 16px", marginBottom: 14, fontSize: 13, color: "#92400e" }}>🇷🇺 {lesson.content.hint_ru_detail}</div>}
      <div style={{ marginBottom: 14 }}>
        <div style={{ fontWeight: 600, color: "#475569", fontSize: 13, marginBottom: 8 }}>💡 Conseils :</div>
        {lesson.content.tips.map((tip, i) => <div key={i} style={{ fontSize: 13, color: "#64748b", marginBottom: 4 }}>• {tip}</div>)}
      </div>
      <textarea value={text} onChange={e => { if (!submitted) setLessonState(p => ({ ...p, text: e.target.value })); }} rows={8}
        style={{ width: "100%", borderRadius: 12, border: `2px solid ${mod.color}60`, padding: "12px 14px", fontSize: 14, fontFamily: "inherit", resize: "vertical", outline: "none", color: "#1e293b", lineHeight: 1.7, boxSizing: "border-box" }} />
      <div style={{ fontSize: 12, color: "#94a3b8", marginTop: 4 }}>{wordCount} mots</div>
      {!submitted ? (
        <Btn onClick={() => setLessonState(p => ({ ...p, submitted: true }))} color={mod.color} disabled={wordCount < 20}>Soumettre ma réponse</Btn>
      ) : (
        <div>
          <div style={{ background: "#dcfce7", border: "1.5px solid #16a34a", borderRadius: 12, padding: "14px 18px", fontWeight: 700, color: "#166534", marginTop: 12 }}>🎉 Bravo ! Ta rédaction est enregistrée. Continue comme ça !</div>
          <Btn onClick={() => completeLesson(lesson.id, lesson.xp)} color={mod.color} disabled={alreadyDone}>{alreadyDone ? "✓ Complété" : "Continuer →"}</Btn>
        </div>
      )}
    </div>
  );
}

function ModuleCompleteScreen({ mod, setScreen, xp, maxXp, earnedBadges }) {
  return (
    <div style={{ maxWidth: 500, margin: "60px auto", padding: "0 16px", textAlign: "center" }}>
      <div style={{ fontSize: 64, marginBottom: 16 }}>🎉</div>
      <h2 style={{ fontSize: 24, fontWeight: 800, color: "#1e293b" }}>Module complété !</h2>
      <p style={{ color: "#64748b", fontSize: 16 }}>Tu as terminé <strong>{mod.title}</strong> à {mod.city} !</p>
      <div style={{ background: mod.bg, border: `2px solid ${mod.color}40`, borderRadius: 16, padding: 20, margin: "20px 0" }}>
        <div style={{ fontSize: 40, marginBottom: 8 }}>{mod.icon}</div>
        <div style={{ fontWeight: 800, color: mod.color, fontSize: 22 }}>{xp} XP total</div>
        <div style={{ background: "#e2e8f0", borderRadius: 99, height: 10, margin: "12px 0 4px", overflow: "hidden" }}>
          <div style={{ width: `${Math.round((xp / maxXp) * 100)}%`, background: `linear-gradient(90deg, ${mod.color}, #a855f7)`, height: "100%", borderRadius: 99 }} />
        </div>
        <div style={{ color: "#94a3b8", fontSize: 13 }}>{Math.round((xp / maxXp) * 100)}% du cours total</div>
      </div>
      {earnedBadges.length > 0 && <div style={{ marginBottom: 20 }}>{earnedBadges.map(b => <span key={b.id} style={{ fontSize: 28, margin: "0 6px" }}>{b.icon}</span>)}</div>}
      <button onClick={() => setScreen("home")} style={{ background: mod.color, color: "#fff", border: "none", borderRadius: 99, padding: "14px 32px", fontWeight: 700, fontSize: 16, cursor: "pointer" }}>
        Retour au menu principal →
      </button>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
  </script>
</body>
</html>
