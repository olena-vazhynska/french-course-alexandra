    body { background: #f8fafc; font-family: 'Segoe UI', sans-serif; }
  </style>
</head>
<body>
  <div id="root"></div>
  <script type="text/babel">
const { useState, useCallback } = React;

const COURSE = {
  title: "Le Français en Voyage 🌍",
  subtitle: "Parcours interactif B1 pour Alexandra",
  modules: [
    {
      id: 0, icon: "🗼", city: "Paris, France", title: "À Paris",
