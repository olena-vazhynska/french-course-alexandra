              { q: "Pour combien de nuits Alexandra a-t-elle réservé ?", options: ["Deux nuits", "Trois nuits", "Une semaine", "Quatre nuits"], answer: 1 },
              { q: "À quel étage est la chambre ?", options: ["Premier", "Troisième", "Deuxième", "Rez-de-chaussée"], answer: 2 },
